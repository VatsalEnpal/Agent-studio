{
  "projects": [
    {
      "name": "staging-frontend",
      "path": "/tmp/shiploop-test-project",
      "isProd": false
    },
    {
      "name": "production-app",
      "path": "/tmp/shiploop-test-project-2",
      "isProd": true,
      "trackedBranches": ["main"]
    }
  ],
  "agentSystem": {
    "path": "/tmp/shiploop-test-project/ai-agents",
    "memoryIndex": "tools/memory_index.json",
    "sprintDir": "sprints/",
    "scanLog": "sprints/scan_log.md"
  },
  "devServers": [
    {
      "name": "frontend",
      "path": "/tmp/shiploop-test-project",
      "command": "npm run dev"
    }
  ],
  "defaults": {
    "model": "sonnet",
    "permissions": "bypass",
    "workingDirectory": "/tmp/shiploop-test-project"
  },
  "setupComplete": true,
  "version": "1.0.0"
}
